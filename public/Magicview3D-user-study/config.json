{
  "$schema": "https://raw.githubusercontent.com/revisit-studies/study/v2.3.2/src/parser/StudyConfigSchema.json",
  "studyMetadata": {
    "title": "Magicview3D post-task survey & Nasa TLX and post-study interview",
    "version": "test-version-1",
    "authors": [
      "The magic-scan-team"
    ],
    "date": "2026-07-03",
    "description": "A study to collect post-task survey, Nasa TLX for the Magicview3D User Study.",
    "organizations": [
      "Tulane University"
    ]
  },
  "uiConfig": {
    "contactEmail": "contact@revisit.dev",
    "helpTextPath": "Magicview3D-user-study/assets/help.md",
    "logoPath": "revisitAssets/revisitLogoSquare.svg",
    "withProgressBar": true,
    "autoDownloadStudy": false,
    "withSidebar": false,
    "windowEventDebounceTime": 200
  },
  "importedLibraries": [
    "nasa-tlx-modified"
  ],
  "components": {
    "introduction": {
      "type": "markdown",
      "path": "Magicview3D-user-study/assets/introduction.md",
     "response": [
        {
          "id": "prolific-id",
           "required": true,
          "prompt": "Please enter Participant ID",
          "location": "belowStimulus",
          "type": "shortText",
          "placeholder": "Participant ID"
        }
      ]
    },
    "post-task-survey": {
        "type": "questionnaire",
        "response": [
                {
                    "id": "q1",
                    "prompt": "On a scale of 1-5, how confident are you that your localization was accurate?",
                    "secondaryText": "1 = Not at all confident, 5 = Extremely confident",
                    "location": "aboveStimulus",
                    "type": "matrix-radio",
                    "answerOptions": "satisfaction5",
                    "questionOptions": [
                        "Task C (3D-to-Physical Localization):"
                    ]
                },
                {
                  "id": "q2",
                  "prompt": "On a scale of 1-5, how easy was it to understand the 3D anatomy using this display mode?",
                  "type": "likert",
                  "location": "belowStimulus",
                  "numItems": 5,
                  "start": 1,
                  "leftLabel": "Not easy at all",
                  "rightLabel": "Extremely easy",
                  "required": false,
                  "style": {
                    "width": "1900px",
                    "margin": "30px auto",
                    "padding": "20px",
                    "background": "linear-gradient(to bottom right, #f5f5f5, #e0e0e0)",
                    "borderRadius": "12px",
                    "textAlign": "left"
                  }
                },
                {
                  "id": "q3",
                  "prompt": "On a scale of 1-5, how suitable is this display mode for localization tasks?",
                  "type": "likert",
                  "location": "belowStimulus",
                  "numItems": 5,
                  "start": 1,
                  "leftLabel": "Not suitable at all",
                  "rightLabel": "Extremely suitable",
                  "required": false,
                  "style": {
                    "width": "1900px",
                    "margin": "30px auto",
                    "padding": "20px",
                    "background": "linear-gradient(to bottom right, #f5f5f5, #e0e0e0)",
                    "borderRadius": "12px",
                    "textAlign": "left"
                  }
                },

                {
                  "id": "q4",
                  "prompt": "Did you experience any discomfort while using this display mode? (e.g., headache, eye strain, dizziness, etc.)",
                  "type": "longText",
                  "location": "belowStimulus",
                  "required": false
                }
               
            ]
        
    },
     "Display-1": 
    {
        "type": "markdown",
        "path": "Magicview3D-user-study/assets/post-task-survey-1.md",
        "response": []
    },
    "Display-2": 
    {
          "type": "markdown",
          "path": "Magicview3D-user-study/assets/post-task-survey-2.md",
          "response": []
      },
      "Display-3": 
      {
          "type": "markdown",
          "path": "Magicview3D-user-study/assets/post-task-survey-3.md",
          "response": []
      }
    
  },
  "sequence": {
    "order": "fixed",
    "components": [
      "introduction",
      "Display-1",
      "post-task-survey",
      "$nasa-tlx-modified.co.nasa-tlx",
      "Display-2",
      "post-task-survey",
      "$nasa-tlx-modified.co.nasa-tlx",
      "Display-3",
      "post-task-survey",
      "$nasa-tlx-modified.co.nasa-tlx"
    ]
  }
}